<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8" />
    <title>Speisekarte – Bäckerei Alisa</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400;500&display=swap"
        rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --dark: #2C1A0A;
            --brown: #8B6340;
            --mid: #C4A882;
            --light: #F2E8DC;
            --bg: #FAF6F1;
            --bg2: #EEE4D6;
            --muted: #8B7355;
        }

        body {
            font-family: 'Jost', sans-serif;
            font-weight: 300;
            background: #999;
        }

        .page {
            width: 210mm;
            background: var(--bg);
            margin: 8mm auto;
            padding: 10mm 12mm 12mm;
            page-break-after: always;
            break-after: page;
        }

        .page.dark {
            background: var(--dark);
        }

        /* HEADER MIT FOTOS */
        .ph {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 5mm;
            margin-bottom: 6mm;
            padding-bottom: 4mm;
            border-bottom: 1px solid var(--mid);
            align-items: center;
        }

        .page.dark .ph {
            border-bottom-color: rgba(196, 168, 130, .3);
        }

        /* FOTOS LINKS */
        .ph-photos-left {
            display: flex;
            flex-direction: row;
            gap: 1mm;
            align-items: flex-end;
        }

        .ph-photos-left img {
            height: 32mm;
            width: auto;
            border: 4px solid #fff;
            box-shadow: 3px 4px 10px rgba(44, 26, 10, .18);
        }

        .ph-photos-left img:nth-child(1) {
            transform: rotate(-2.5deg);
        }

        .ph-photos-left img:nth-child(2) {
            transform: rotate(2deg);
            margin-bottom: 4mm;
        }

        .ph-photos-left img:nth-child(3) {
            transform: rotate(-1deg);
        }

        .page.dark .ph-photos-left img {
            border-color: rgba(255, 255, 255, .15);
            box-shadow: 3px 4px 10px rgba(0, 0, 0, .4);
        }

        /* FOTOS RECHTS */
        .ph-photos-right {
            display: flex;
            flex-direction: row;
            gap: 1mm;
            align-items: flex-end;
            justify-content: flex-end;
        }

        .ph-photos-right img {
            height: 32mm;
            width: auto;
            border: 4px solid #fff;
            box-shadow: 3px 4px 10px rgba(44, 26, 10, .18);
        }

        .ph-photos-right img:nth-child(1) {
            transform: rotate(2.5deg);
        }

        .ph-photos-right img:nth-child(2) {
            transform: rotate(-2deg);
            margin-bottom: 4mm;
        }

        .ph-photos-right img:nth-child(3) {
            transform: rotate(1deg);
        }

        .page.dark .ph-photos-right img {
            border-color: rgba(255, 255, 255, .15);
            box-shadow: 3px 4px 10px rgba(0, 0, 0, .4);
        }

        /* HEADER TEXT MITTE */
        .ph-text {
            text-align: center;
        }

        .ph-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-style: italic;
            color: var(--dark);
        }

        .page.dark .ph-title {
            color: var(--light);
        }

        .ph-sub {
            font-size: 7.5px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 3px;
        }

        .page.dark .ph-sub {
            color: var(--mid);
        }

        /* HEADER NUR TEXT+FOTOS RECHTS (Getränke) */
        .ph-right-only {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 5mm;
            margin-bottom: 6mm;
            padding-bottom: 4mm;
            border-bottom: 1px solid rgba(196, 168, 130, .3);
            align-items: center;
        }

        .ph-right-only .ph-text {
            text-align: left;
        }

        .ph-right-only .ph-title {
            color: var(--light);
        }

        .ph-right-only .ph-sub {
            color: var(--mid);
        }

        /* SEKTION */
        .section {
            margin-bottom: 5mm;
        }

        .st {
            font-size: 8px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--muted);
            background: var(--bg2);
            padding: 4px 10px;
            display: inline-block;
            margin-bottom: 2mm;
        }

        .page.dark .st {
            background: rgba(196, 168, 130, .1);
            color: var(--mid);
        }

        /* ZWEI SPALTEN */
        .mc {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 8mm;
        }

        /* GERICHT */
        .mi {
            padding: 4px 0;
            border-bottom: 0.4px solid #e8d9c5;
        }

        .page.dark .mi {
            border-bottom-color: rgba(196, 168, 130, .12);
        }

        .mt {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 4px;
        }

        .mn {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            font-style: italic;
            color: var(--dark);
            font-weight: 500;
        }

        .page.dark .mn {
            color: var(--light);
        }

        .mp {
            font-size: 13px;
            color: var(--brown);
            white-space: nowrap;
            flex-shrink: 0;
            font-weight: 500;
        }

        .page.dark .mp {
            color: var(--mid);
        }

        .md {
            font-size: 9px;
            color: var(--muted);
            line-height: 1.5;
            margin-top: 1px;
        }

        .page.dark .md {
            color: rgba(196, 168, 130, .6);
        }

        /* FOOTER */
        .pf {
            text-align: center;
            font-size: 7px;
            color: var(--mid);
            letter-spacing: 1px;
            margin-top: 6mm;
            padding-top: 3mm;
            border-top: 0.4px solid var(--mid);
        }

        .page.dark .pf {
            color: rgba(196, 168, 130, .4);
            border-top-color: rgba(196, 168, 130, .2);
        }

        @media print {
            body {
                background: none;
            }

            .page {
                margin: 0;
                width: 210mm;
                min-height: 297mm;
            }

            @page {
                size: 210mm 297mm;
                margin: 0;
            }
        }
    </style>
</head>

